# =============================================================================
# Advanced AI Service Broker — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration (defaults point to LocalStack for local development)
# -----------------------------------------------------------------------------
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# DynamoDB
DYNAMODB_TABLE_NAME=broker-resources
DYNAMODB_METRICS_TABLE_NAME=broker-metrics

# SQS
SQS_QUEUE_URL=http://localhost:4566/000000000000/broker-tasks
SQS_DLQ_URL=http://localhost:4566/000000000000/broker-tasks-dlq

# -----------------------------------------------------------------------------
# LLM / AI Configuration
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# Sovereign (Envoy Control Plane)
# -----------------------------------------------------------------------------
SOVEREIGN_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
APP_HOST=0.0.0.0
APP_PORT=8000

# -----------------------------------------------------------------------------
# Predictive Scaling
# -----------------------------------------------------------------------------
SCALING_PREDICTION_HORIZON_MINUTES=30
SCALING_CONFIDENCE_THRESHOLD=0.8
SCALING_COOLDOWN_SECONDS=300
